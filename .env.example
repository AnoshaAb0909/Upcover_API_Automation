BASE_URL=https://dev-api.upcover.com
REQUEST_TIMEOUT=120000
GUEST_EMAIL=qa-automation@upcover.com

# Shared Stripe keys for all products (Coalition, Viz, future products)
STRIPE_SECRET_KEY_ANNUAL=sk_test_your_annual_key_here
STRIPE_SECRET_KEY_MONTHLY=sk_test_your_monthly_key_here
# Optional legacy fallback if the above are not set
STRIPE_SECRET_KEY=sk_test_your_key_here

# Shared fallback payment method IDs when Stripe lookup is unavailable
FALLBACK_ANNUAL_PAYMENT_METHOD_ID=pm_your_annual_pm_here
FALLBACK_MONTHLY_PAYMENT_METHOD_ID=pm_your_monthly_pm_here

COALITION_QUICK_QUOTE_PATH=/coalition/quick-quote
COALITION_FULL_QUOTE_PATH=/coalition/full-quote
COALITION_PAYMENTS_PATH=/coalition/payments
COALITION_MONTHLY_PAYMENTS_PATH=/coalition/payments/monthly
COALITION_COUPON_ID=ec92858ce2
COALITION_QUOTE_DOCS_EMAIL_PATH=/coalition/quote-docs/email
COALITION_PROOF_OF_INSURANCE_EMAIL_PATH=/coalition/proof-of-insurance/email
QUOTE_DOCS_TIMEOUT=120000

VIZ_QUICK_QUOTE_PATH=/viz/quick-quote
VIZ_FULL_QUOTE_PATH=/viz/full-quote
VIZ_ENDORSEMENT_PATH=/viz/full-quote/endorsement
VIZ_PAYMENTS_PATH=/viz/payments
VIZ_MONTHLY_PAYMENTS_PATH=/viz/payments/monthly
VIZ_ENDORSEMENT_MONTHLY_PAYMENTS_PATH=/viz/payments/endorsement/monthly
VIZ_QUOTE_DOCS_EMAIL_PATH=/viz/quote-docs/email
VIZ_PROOF_OF_INSURANCE_EMAIL_PATH=/viz/proof-of-insurance/email
