{
  "name": "upcover-api-supertest-automation",
  "version": "1.0.0",
  "description": "Upcover backend API QA automation using Jest and Supertest",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:auth": "jest --testPathPatterns=tests/auth",
    "test:coalition": "jest --testPathPatterns=products/coalition --runInBand --testSequencer=./src/tests/coalitionTestSequencer.js",
    "test:ahp": "jest --testPathPatterns=products/ahp",
    "test:viz": "jest --testPathPatterns=products/viz --runInBand --testSequencer=./src/tests/vizTestSequencer.js",
    "test:ci": "jest --testPathIgnorePatterns=products/viz --runInBand",
    "test:report": "jest && open reports/test-report.html"
  },
  "keywords": [
    "api",
    "qa",
    "supertest",
    "jest",
    "upcover"
  ],
  "license": "ISC",
  "dependencies": {
    "dotenv": "^16.4.7",
    "stripe": "^22.3.1",
    "supertest": "^7.1.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.6",
    "@types/supertest": "^6.0.2",
    "jest": "^30.2.0",
    "jest-html-reporter": "^4.3.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
